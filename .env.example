# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_ORG_ID=org-optional-id

# Google Gemini Configuration
curl "https://generativelanguage.googleapis.com/v1beta/models/gemini-flash-latest:generateContent" \
  -H 'Content-Type: application/json' \
  -H 'X-goog-api-key: AQ.Ab8RN6LG7t8xRCLBXgKlCN-MkSRzwm7GtfSwBXedvZkvszlrRA' \
  -X POST \
  -d '{
    "contents": [
      {
        "parts": [
          {
            "text": "Explain how AI works in a few words"
          }
        ]
      }
    ]
  }'

# Black Forest Labs Flux Configuration
FLUX_API_KEY=your-flux-api-key-here
FLUX_ENDPOINT=https://api.blackforestlabs.ai

# Midjourney Configuration (via Discord)
MIDJOURNEY_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-id
MIDJOURNEY_API_KEY=optional-midjourney-api-key

# Application Settings
IMAGE_OUTPUT_DIR=./generated_images
LOG_LEVEL=INFO
LOG_FILE=app.log

# Batch Processing
BATCH_SIZE=5
MAX_RETRIES=3
RETRY_DELAY=2

# Cache Settings
ENABLE_CACHE=true
CACHE_DIR=./cache
CACHE_EXPIRY_HOURS=24
